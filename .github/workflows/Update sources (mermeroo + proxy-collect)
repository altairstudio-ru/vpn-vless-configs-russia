name: Update sources (mermeroo + proxy-collect)

on:
  schedule:
    - cron: "0 */4 * * *"
  workflow_dispatch:

jobs:
  update-sources:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repo
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Install deps
        run: |
          python -m pip install --upgrade pip
          pip install requests

      - name: Run mermeroo merge
        run: |
          python mermeroo_merge.py

      - name: Run proxy-collect merge
        run: |
          python proxy_collect_merge.py

      - name: Commit updated sources
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "41898282+github-actions[bot]@users.noreply.github.com"
          git add config_sources.json mermeroo_only_new_for_mirror.txt mermeroo_extra_sources.txt proxy_collect_only_new_for_mirror.txt proxy_collect_extra_sources.txt || true
          if ! git diff --cached --quiet; then
            git commit -m "Update sources (mermeroo + proxy-collect)"
            git push
          fi
